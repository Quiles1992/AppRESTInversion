# =============================================
# AppRESTInversionsApi - REST Client
# ITT - Bases de Datos NoSQL - G5B 7pm
# Docente: Francisco Ibarra Carlos
# =============================================
# Uso: Abre este archivo en VS Code con la extension REST Client
# Haz click en "Send Request" sobre cada peticion
# Agrega ?DBServer=supabase para usar Supabase
# =============================================

@api = http://localhost:3020/api/v1

# =============================================
# 1. USERS
# =============================================

### GET ALL - Obtener todos los usuarios (MongoDB)
GET {{api}}/users

###
### GET ALL - Obtener todos los usuarios (Supabase)
GET {{api}}/users?DBServer=supabase

###
### GET BY ID - Obtener usuario por ID
GET {{api}}/users/REEMPLAZA_CON_ID

###
### POST - Crear usuario
POST {{api}}/users
Content-Type: application/json

{
  "email": "trader@inversions.com",
  "full_name": "Trader Demo",
  "role": "trader",
  "timezone": "America/Mexico_City",
  "is_active": true,
  "preferences": {},
  "risk_config": {
    "max_position_size_pct": 5,
    "max_daily_loss_pct": 2,
    "default_stop_loss_pct": 1.5,
    "default_take_profit_pct": 3
  },
  "broker_accounts": [
    {
      "broker": "alpaca",
      "account_id": "ACC123",
      "environment": "paper",
      "is_active": true
    }
  ]
}

###
### PUT - Actualizar usuario
PUT {{api}}/users/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "full_name": "Trader Actualizado",
  "timezone": "UTC"
}

###
### DELETE - Eliminar usuario
DELETE {{api}}/users/REEMPLAZA_CON_ID


# =============================================
# 2. STRATEGIES
# =============================================

### GET ALL
GET {{api}}/strategies

###
### POST - Crear estrategia
POST {{api}}/strategies
Content-Type: application/json

{
  "user_id": "REEMPLAZA_CON_USER_ID",
  "name": "Momentum Strategy",
  "description": "Estrategia basada en momentum con RSI y MACD",
  "min_confidence_threshold": 0.5,
  "is_active": true
}

###
### PUT - Actualizar estrategia
PUT {{api}}/strategies/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "name": "Momentum Strategy v2",
  "min_confidence_threshold": 0.65
}

###
### DELETE
DELETE {{api}}/strategies/REEMPLAZA_CON_ID


# =============================================
# 3. SIGNAL EVENTS
# =============================================

### GET ALL
GET {{api}}/signal-events

###
### GET - Filtrar por symbol
GET {{api}}/signal-events?symbol=AAPL

###
### POST - Crear señal
POST {{api}}/signal-events
Content-Type: application/json

{
  "symbol": "AAPL",
  "timeframe": "1h",
  "action": "BUY",
  "confidence": 0.85,
  "score": 90,
  "strategy_id": "REEMPLAZA_CON_STRATEGY_ID",
  "price_at_signal": 182.50,
  "status": "active",
  "reason": "RSI oversold + MACD bullish cross"
}

###
### PUT - Actualizar señal
PUT {{api}}/signal-events/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "status": "executed",
  "confidence": 0.90
}

###
### DELETE
DELETE {{api}}/signal-events/REEMPLAZA_CON_ID


# =============================================
# 4. ORDERS
# =============================================

### GET ALL
GET {{api}}/orders

###
### GET - Filtrar por user_id
GET {{api}}/orders?user_id=REEMPLAZA_CON_USER_ID

###
### POST - Crear orden
POST {{api}}/orders
Content-Type: application/json

{
  "user_id": "REEMPLAZA_CON_USER_ID",
  "signal_id": "REEMPLAZA_CON_SIGNAL_ID",
  "strategy_id": "REEMPLAZA_CON_STRATEGY_ID",
  "symbol": "AAPL",
  "side": "BUY",
  "quantity": 10,
  "order_type": "MARKET",
  "status": "FILLED",
  "filled_qty": 10,
  "filled_avg_price": 182.50
}

###
### PUT - Actualizar orden
PUT {{api}}/orders/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "status": "FILLED",
  "filled_qty": 10,
  "filled_avg_price": 183.00
}

###
### DELETE
DELETE {{api}}/orders/REEMPLAZA_CON_ID


# =============================================
# 5. POSITIONS
# =============================================

### GET ALL
GET {{api}}/positions

###
### POST - Crear posición
POST {{api}}/positions
Content-Type: application/json

{
  "user_id": "REEMPLAZA_CON_USER_ID",
  "symbol": "AAPL",
  "side": "LONG",
  "quantity": 10,
  "entry_price": 182.50,
  "current_price": 185.00,
  "stop_loss": 178.00,
  "take_profit": 192.00,
  "is_open": true
}

###
### PUT - Actualizar posición
PUT {{api}}/positions/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "current_price": 187.30,
  "unrealized_pnl": 48.00,
  "unrealized_pnl_pct": 2.63
}

###
### DELETE
DELETE {{api}}/positions/REEMPLAZA_CON_ID


# =============================================
# 6. CLOSED TRADES
# =============================================

### GET ALL
GET {{api}}/closed-trades

###
### POST - Registrar trade cerrado
POST {{api}}/closed-trades
Content-Type: application/json

{
  "user_id": "REEMPLAZA_CON_USER_ID",
  "symbol": "AAPL",
  "side": "BUY",
  "quantity": 10,
  "entry_price": 182.50,
  "exit_price": 190.00,
  "pnl": 75.00,
  "pnl_pct": 4.11,
  "entry_time": "2026-04-20T09:30:00Z",
  "exit_time": "2026-04-24T15:45:00Z"
}

###
### PUT - Actualizar trade
PUT {{api}}/closed-trades/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "pnl": 80.00,
  "pnl_pct": 4.38
}

###
### DELETE
DELETE {{api}}/closed-trades/REEMPLAZA_CON_ID


# =============================================
# 7. ALERT LOG
# =============================================

### GET ALL
GET {{api}}/alert-log

###
### GET - Filtrar por user_id
GET {{api}}/alert-log?user_id=REEMPLAZA_CON_USER_ID

###
### POST - Crear alerta
POST {{api}}/alert-log
Content-Type: application/json

{
  "user_id": "REEMPLAZA_CON_USER_ID",
  "alert_type": "SIGNAL_HIGH_CONFIDENCE",
  "symbol": "AAPL",
  "message": "Señal de compra detectada en AAPL con confianza 85%",
  "channel": "ui"
}

###
### PUT - Marcar alerta como leída
PUT {{api}}/alert-log/REEMPLAZA_CON_ID
Content-Type: application/json

{
  "acknowledged": true,
  "acknowledged_at": "2026-04-26T10:00:00Z"
}

###
### DELETE
DELETE {{api}}/alert-log/REEMPLAZA_CON_ID


